<main class="nxl-container">
  <div class="nxl-content">
    <!-- [ page-header ] start -->
    <div class="page-header">
        <div class="page-header-left d-flex align-items-center">
            <div class="page-header-title">
                <h5 class="m-b-10">Sessions</h5>
            </div>
            <ul class="breadcrumb">
                <li class="breadcrumb-item"><a href="/dashboard">Home</a></li>
                <li class="breadcrumb-item">Sessions</li>
            </ul>
        </div>
    </div>
    <!-- [ page-header ] end -->

    <div class="main-content">
      <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center">
            <div class="input-group" style="max-width: 400px;">
              <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-plus-circle-fill text-primary"></i>
              </span>
              <input type="text" id="newSessionDesc" class="form-control border-start-0" placeholder="Deskripsi sesi baru...">
            </div>
            <button class="btn btn-primary px-4" onclick="createSession()">
              <i class="bi bi-plus-lg me-2"></i>Buat Session
            </button>
          </div>
        </div>
      </div>
          
      <div id="session-list" class="row g-4">
        <div class="col-12 text-center py-5">
          <div class="spinner-border text-primary" role="status"></div>
          <p class="mt-3 text-muted">Memuat data...</p>
        </div>
      </div>
    </div>
  </div>
</main>

<style>
  .session-card {
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    border: 1px solid rgba(0,0,0,0.05) !important;
  }
  
  .session-card:hover {
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.08) !important;
    transform: translateY(-6px);
    border-color: rgba(74, 107, 255, 0.2) !important;
  }
  
  .avatar-text {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bg-soft-primary { background-color: rgba(74, 107, 255, 0.1); }
  .text-primary { color: #4a6bff !important; }
  
  .bg-soft-success { background-color: rgba(32, 201, 151, 0.1); }
  .text-success { color: #20c997 !important; }
  
  .bg-soft-danger { background-color: rgba(220, 53, 69, 0.1); }
  .text-danger { color: #dc3545 !important; }

  .bg-soft-warning { background-color: rgba(255, 193, 7, 0.1); }

  .border-dashed {
    border-top: 1px dashed rgba(0,0,0,0.1);
    opacity: 1;
  }

  .font-monospace {
    font-family: 'SFMono-Regular', Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
  }

  /* Smooth fade icon on hover */
  .session-card .manage-icon {
    transition: transform 0.2s ease;
  }
  .session-card:hover .manage-icon {
    transform: translateX(4px);
  }

  .btn-primary {
    background: linear-gradient(135deg, #4a6bff 0%, #3955d8 100%);
    border: none;
    box-shadow: 0 4px 12px rgba(74, 107, 255, 0.25);
    transition: all 0.3s ease;
  }
  
  .btn-primary:hover {
    background: linear-gradient(135deg, #3955d8 0%, #2f45b5 100%);
    box-shadow: 0 6px 16px rgba(74, 107, 255, 0.35);
    transform: translateY(-1px);
  }
</style>

<script>
  async function loadSessions() {
    const token = localStorage.getItem('token');
    const container = document.getElementById('session-list');
    container.innerHTML = `
      <div class="col-12 text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Memuat data...</p>
      </div>
    `;

    try {
      const sessionsUrl = window.AppConfig && window.AppConfig.apiBaseUrl 
        ? `${window.AppConfig.apiBaseUrl}/whatsapp/sessions`
        : '/api/whatsapp/sessions';
        
      const response = await fetch(sessionsUrl, {
        headers: {
          'Authorization': `Bearer ${token}`
        }
      });

      const data = await response.json();

      if (!data.success) {
        container.innerHTML = `
          <div class="col-12 text-center py-5">
            <i class="feather-alert-circle text-danger fs-1 mb-3"></i>
            <h5 class="text-danger">Gagal memuat session</h5>
            <p class="text-muted">Silakan coba lagi nanti</p>
          </div>
        `;
        return;
      }

      if (data.sessions.length === 0) {
        container.innerHTML = `
          <div class="col-12 text-center py-5">
            <i class="feather-inbox fs-1 text-muted mb-3 d-block"></i>
            <h5 class="text-muted">Tidak ada session ditemukan</h5>
            <p class="text-muted">Buat session baru untuk memulai mengirim pesan</p>
          </div>
        `;
        return;
      }

      container.innerHTML = '';

      data.sessions.forEach((session) => {
        const card = document.createElement('div');
        card.className = 'col-md-6 col-lg-4 col-xl-3'; // Responsive grid fit for Pro UI

        const formattedDate = new Date(session.created_at).toLocaleDateString('id-ID', {
          day: 'numeric',
          month: 'short',
          year: 'numeric'
        });

        // Determine Status Styles
        const statusBadgeClasses = session.isConnected 
          ? 'bg-soft-success text-success' 
          : 'bg-soft-danger text-danger';

        const statusIcon = session.isConnected 
          ? '<i class="feather-check-circle me-1"></i>' 
          : '<i class="feather-wifi-off me-1"></i>';
        
        // Determine QR Status View
        let qrStatusHtml = '';
        if (session.isConnected) {
            qrStatusHtml = '<span class="text-success"><i class="feather-shield"></i> Synced</span>';
        } else if (session.hasQrCode) {
            qrStatusHtml = '<span class="text-warning"><i class="feather-maximize"></i> Scan Ready</span>';
        } else {
            qrStatusHtml = '<span class="text-danger"><i class="feather-x"></i> Invalid</span>';
        }

        // WhatsApp Phone Number or ID
        const phoneStr = String(session.phoneNumber || '');
        const isValidPhone = phoneStr && phoneStr !== 'Unknown' && phoneStr !== '[object Object]';
        const phoneDisplay = isValidPhone 
          ? `+${phoneStr.split('@')[0]}` 
          : `${session.session_id.substring(0, 8)}...`;

        card.innerHTML = `
          <a href="/sessions/detail?id=${session.session_id}" class="text-decoration-none">
            <div class="card h-100 bg-white session-card rounded-4 overflow-hidden position-relative">
              <div class="card-body p-4">
                <!-- Header -->
                <div class="d-flex justify-content-between align-items-start mb-4">
                  <div class="d-flex align-items-center gap-3 w-100 pe-2">
                    <div class="avatar-text flex-shrink-0 bg-soft-primary text-primary rounded-circle">
                      <i class="feather-smartphone fs-5"></i>
                    </div>
                    <div class="text-truncate">
                      <h6 class="fw-bolder text-dark mb-1 text-truncate" title="${session.description || 'WhatsApp Session'}">
                        ${session.description || 'WhatsApp Session'}
                      </h6>
                      <p class="fs-12 text-muted mb-0 font-monospace">${phoneDisplay}</p>
                    </div>
                  </div>
                </div>

                <!-- Divider -->
                <hr class="border-dashed my-3">

                <!-- Details Grid -->
                <div class="row g-3">
                  <div class="col-6">
                    <div class="d-flex align-items-center gap-2 text-muted">
                      <span class="fs-11 text-uppercase fw-bold tracking-wide">Status</span>
                    </div>
                    <div class="mt-1">
                      <span class="badge ${statusBadgeClasses} rounded-pill px-2 py-1 fw-semibold fs-11 d-inline-flex align-items-center">
                        ${statusIcon} ${session.isConnected ? 'Connected' : 'Disconnected'}
                      </span>
                    </div>
                  </div>
                  <div class="col-6">
                    <div class="d-flex align-items-center gap-2 text-muted">
                      <span class="fs-11 text-uppercase fw-bold tracking-wide">Auth Status</span>
                    </div>
                    <p class="fw-semibold fs-13 mb-0 mt-1 d-flex align-items-center gap-1">
                      ${qrStatusHtml}
                    </p>
                  </div>
                </div>
              </div>
              
              <!-- Footer -->
              <div class="card-footer bg-light-subtle bg-opacity-50 border-top-0 px-4 py-3">
                <div class="d-flex justify-content-between align-items-center text-muted fs-12">
                  <span class="d-flex align-items-center gap-1 fw-medium">
                    <i class="feather-calendar fs-12"></i> ${formattedDate}
                  </span>
                  <span class="d-flex align-items-center gap-1 text-primary fw-bold manage-text">
                    Manage <i class="feather-chevron-right fs-12 manage-icon"></i>
                  </span>
                </div>
              </div>
            </div>
          </a>
        `;

        container.appendChild(card);
      });

    } catch (error) {
      console.error('Error saat memuat session:', error);
      container.innerHTML = `
        <div class="col-12 text-center py-5">
          <i class="bi bi-x-circle text-danger fs-1 mb-3"></i>
          <h5 class="text-danger">Terjadi kesalahan</h5>
          <p class="text-muted">Tidak dapat mengambil data dari server</p>
        </div>
      `;
    }
  }

  async function createSession() {
    const token = localStorage.getItem('token');
    const description = document.getElementById('newSessionDesc').value.trim();

    if (!description) {
      showToast('Deskripsi harus diisi', 'warning');
      return;
    }

    try {
      // Menampilkan loading indicator
      const btn = document.querySelector('button[onclick="createSession()"]');
      const originalText = btn.innerHTML;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Membuat...';
      btn.disabled = true;
      
      const createSessionUrl = window.AppConfig && window.AppConfig.apiBaseUrl 
        ? `${window.AppConfig.apiBaseUrl}/whatsapp/session`
        : '/api/whatsapp/session';
        
      const res = await fetch(createSessionUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({ description })
      });

      const data = await res.json();

      if (data.success) {
        showToast('Session berhasil dibuat. QR Code akan muncul di detail.', 'success');
        loadSessions(); // refresh daftar session
        document.getElementById('newSessionDesc').value = ''; // kosongkan input
      } else {
        showToast('Gagal membuat session: ' + data.message, 'error');
      }
      
      // Kembalikan button ke keadaan semula
      btn.innerHTML = originalText;
      btn.disabled = false;
      
    } catch (error) {
      console.error('Gagal membuat session:', error);
      showToast('Terjadi kesalahan saat membuat session.', 'error');
      
      // Kembalikan button ke keadaan semula
      const btn = document.querySelector('button[onclick="createSession()"]');
      btn.innerHTML = originalText;
      btn.disabled = false;
    }
  }
  
  function showToast(message, type = 'info') {
    // Cek apakah container toast sudah ada
    let toastContainer = document.querySelector('.toast-container');
    if (!toastContainer) {
      toastContainer = document.createElement('div');
      toastContainer.className = 'toast-container position-fixed bottom-0 end-0 p-3';
      document.body.appendChild(toastContainer);
    }
    
    // Tentukan warna berdasarkan tipe
    let bgColor = 'bg-primary';
    if (type === 'success') bgColor = 'bg-success';
    if (type === 'warning') bgColor = 'bg-warning text-dark';
    if (type === 'error') bgColor = 'bg-danger';
    
    // Buat element toast
    const toastEl = document.createElement('div');
    toastEl.className = `toast ${bgColor} text-white`;
    toastEl.setAttribute('role', 'alert');
    toastEl.setAttribute('aria-live', 'assertive');
    toastEl.setAttribute('aria-atomic', 'true');
    
    toastEl.innerHTML = `
      <div class="toast-header">
        <strong class="me-auto">${type.charAt(0).toUpperCase() + type.slice(1)}</strong>
        <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
      </div>
      <div class="toast-body">
        ${message}
      </div>
    `;
    
    toastContainer.appendChild(toastEl);
    
    // Gunakan Bootstrap Toast API
    const toast = new bootstrap.Toast(toastEl);
    toast.show();
    
    // Hapus toast setelah ditampilkan
    toastEl.addEventListener('hidden.bs.toast', function() {
      toastEl.remove();
    });
  }

  // Jalankan saat halaman dimuat
  window.addEventListener('DOMContentLoaded', loadSessions);
</script>